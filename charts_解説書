  <tr><td><code>px.line</code></td><td>折れ線グラフ</td><td>年別トレンド</td></tr>
  <tr><td><code>px.scatter</code></td><td>散布図・バブルチャート</td><td>バブルチャート</td></tr>
  <tr><td><code>px.pie</code></td><td>円グラフ・ドーナツ</td><td>特定出願人のIPC分布</td></tr>
</table>

<h3>update_layout の主な設定</h3>
<table>
  <tr><th>設定</th><th>効果</th></tr>
  <tr><td><code>xaxis_title="出願年"</code></td><td>X軸のタイトル文字を変更</td></tr>
  <tr><td><code>yaxis_title="出願人"</code></td><td>Y軸のタイトル文字を変更</td></tr>
  <tr><td><code>xaxis={"dtick": 1}</code></td><td>X軸の目盛り間隔を1にする</td></tr>
  <tr><td><code>yaxis={"categoryorder": "total ascending"}</code></td><td>Y軸を件数の昇順に並べる</td></tr>
